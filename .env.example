# Đổi tên file này thành ".env" khi chạy ở local (KHÔNG commit file .env lên Git)

# Connection string của PostgreSQL (Render sẽ tự cung cấp khi bạn tạo PostgreSQL database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Chuỗi bí mật dùng để ký JWT - hãy đổi thành một chuỗi ngẫu nhiên, khó đoán
JWT_SECRET=thay-doi-chuoi-bi-mat-nay

# Cổng chạy server (Render sẽ tự set biến PORT, để local có thể dùng 3000)
PORT=3000
NODE_ENV=production
